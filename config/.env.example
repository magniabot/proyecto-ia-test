# ─────────────────────────────────────────────────────────────
# Plantilla de variables de entorno
#
# Copiar como `config/.env` y completar con las credenciales
# propias. El archivo `.env` real está excluido del repositorio
# y NUNCA debe versionarse.
#
#   cp config/.env.example config/.env
#
# No todas son obligatorias: depende de qué skills se usen.
# ─────────────────────────────────────────────────────────────

# ── Google Ads API ───────────────────────────────────────────
# Requerido por: gads-context, todos los auditores y optimizadores
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=

# ── Meta / Facebook Ads API ──────────────────────────────────
# Requerido por: meta-context, meta-bulk-uploader
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PIXEL_ID=
FACEBOOK_PAGE_ID=
INSTAGRAM_ACCOUNT_ID=

# ── GoHighLevel (CRM) ────────────────────────────────────────
# Requerido por: dashboard-global, email-nurture
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_IDENTIFICADOR_SECRETO=

# ── DataForSEO ───────────────────────────────────────────────
# Requerido por: competitor-scraper
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ── Modelos de lenguaje (opcional) ───────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Flags de desarrollo (opcional) ───────────────────────────
# FEED_AUDITOR_DEBUG=1
# FEED_OPTIMIZER_MOCK_LLM=1
